rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection — each user can only access their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /reviews/{userId} {
      // Anyone can read reviews
      allow read: if true;

      // Allow users to write their own review
      // The document ID must match the authenticated user's ID
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && validateReview(request.resource.data);
    }
    
    // Function to validate the review shape and sizes, preventing massive spam payloads
    function validateReview(data) {
      return data.keys().hasAll(['username', 'rating', 'feedback', 'createdAt'])
        && data.username is string 
        && data.username.size() > 0 
        && data.username.size() <= 50
        && data.rating is number 
        && data.rating >= 1 
        && data.rating <= 5
        && data.feedback is string 
        && data.feedback.size() <= 1000;
    }
  }
}
